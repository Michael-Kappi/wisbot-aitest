# OpenAI API Key (or enterprise gateway key)
OPENAI_API_KEY=your-api-key-here

# Optional: Custom API base URL for enterprise LLM gateways
# If your organisation uses a gateway that hosts multiple models (OpenAI, Claude, DeepSeek, etc.)
# set this to the gateway's OpenAI-compatible endpoint.
# OPENAI_BASE_URL=https://llm-gateway.yourcompany.com/v1

# Optional: Custom header name for the API key (enterprise gateways)
# Standard OpenAI uses "Authorization: Bearer <key>" by default.
# Many enterprise gateways expect the key in a different header, e.g. "api-key".
# OPENAI_API_HEADER=api-key

# Optional: API version parameter (required by some enterprise gateways, e.g. Azure)
# OPENAI_API_VERSION=2024-02-01

# Optional: Override the default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Server port (default: 3001)
# PORT=3001
