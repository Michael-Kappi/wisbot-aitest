# OpenAI API Key (or enterprise gateway key)
OPENAI_API_KEY=your-api-key-here

# Optional: Custom API base URL for enterprise LLM gateways
# If your organisation uses a gateway that hosts multiple models (OpenAI, Claude, DeepSeek, etc.)
# set this to the gateway's OpenAI-compatible endpoint.
# OPENAI_BASE_URL=https://llm-gateway.yourcompany.com/v1

# Optional: Override the default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Server port (default: 3001)
# PORT=3001
